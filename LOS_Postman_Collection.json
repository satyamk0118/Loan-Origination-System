            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Ravi Kumar\",\n  \"customerPhone\": \"+919876543210\",\n  \"loanAmount\": 500000,\n  \"loanType\": \"PERSONAL\"\n}"
